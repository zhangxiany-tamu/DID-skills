# === Monorepo root .gitignore ===
# Per-subtree .gitignore files add subdirectory-specific patterns.

# Local maintainer notes
CLAUDE.md

# Academic paper and its figures (tracked in a separate repo)
paper.md
figures/

# Local Claude Code configuration (user-specific permissions, scheduled tasks)
.claude/

# AI tooling scratch/plan artifacts
.plans/

# OS files
.DS_Store
Thumbs.db
Desktop.ini
*~
.Spotlight-V100
.Trashes
Icon?

# Google Drive sync artifacts (files like `main (1)`, `foo (2).md`)
* (1)
* (2)
* (3)

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# === MCP (Node/TypeScript) ===
mcp/node_modules/
mcp/dist/
mcp/.nvmrc.lock
mcp/npm-debug.log*
mcp/yarn-error.log*
mcp/coverage/

# === MCP runtime artifacts ===
mcp/tmp/
mcp/validation-output/
/tmp/did-mcp/

# === Skill runtime artifacts ===
skill/validation-output/

# === R build artifacts (monorepo-wide) ===
*.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rcheck/
*.tar.gz
*.rda
