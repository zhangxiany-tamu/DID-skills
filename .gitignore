# === Monorepo root .gitignore ===
# Per-subtree .gitignore files add subdirectory-specific patterns.

# Local maintainer notes
CLAUDE.md

# OS files
.DS_Store
Thumbs.db
Desktop.ini
*~
.Spotlight-V100
.Trashes

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# === MCP (Node/TypeScript) ===
mcp/node_modules/
mcp/dist/
mcp/.nvmrc.lock
mcp/npm-debug.log*
mcp/yarn-error.log*
mcp/coverage/

# === MCP runtime artifacts ===
mcp/tmp/
/tmp/did-mcp/

# === R build artifacts (monorepo-wide) ===
*.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rcheck/
*.tar.gz
*.rda
*.rds
*.rdb
*.rdx
*.o
*.so
*.dll
*.dylib
